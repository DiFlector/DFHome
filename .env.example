# Optional: seed values on first container boot. After that, use the
# Settings page in the app — it's the source of truth (stored in SQLite).
YANDEX_OAUTH_TOKEN=
QUASAR_COOKIE=
QUASAR_CSRF_TOKEN=
# HTTP proxy for the weather widget's open-meteo requests (unreachable
# directly from some networks). Format: http://login:password@host:port
# Leave empty to connect directly.
WEATHER_PROXY=
